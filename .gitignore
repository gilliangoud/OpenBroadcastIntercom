/target/

.DS_Store
**/.DS_Store
*.log
__pycache__/
*.pyc

# Local runtime state and operator settings.
/intercom-state.json
/intercom-app-settings.json
/debug-audio/
/artifacts/

/clients/esp32/build/
/clients/esp32/managed_components/
/clients/esp32/sdkconfig
/clients/esp32/sdkconfig.*
/clients/esp32/sdkconfig\ [0-9]*

/clients/app/gen/apple/build/
/clients/app/gen/apple/Externals/
/clients/app/gen/apple/**/*.xcarchive
/clients/app/gen/apple/**/*.ipa
/clients/app/gen/android/.gradle/
/clients/app/gen/android/buildSrc/.gradle/
/clients/app/gen/android/**/build/

# Release bundles are produced by GitHub Actions and local packaging scripts.
*.AppImage
*.deb
*.rpm
*.dmg
*.msi
*.apk
*.aab
*.ipa

# Finder duplicate files and local git backups.
**/*\ [0-9]
**/*\ [0-9].*
.git.local-*

# Large optional Whisper models not part of the public LFS set.
/intercom-models/ggml-medium-*.bin
/intercom-models/ggml-large-*.bin

# Private signing material must never be committed.
*.mobileprovision
*.provisionprofile
*.p12
*.pem
*.key
*.cer
*.der
*.certSigningRequest
*.csr
