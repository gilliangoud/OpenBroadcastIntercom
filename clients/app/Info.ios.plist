<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Intercom Suite needs microphone access so this device can transmit intercom audio.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Intercom Suite needs local network access to connect to your intercom server over UDP and WebSocket.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_intercom-suite._tcp</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
